<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
</head>

<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/listings" class="nav-logo">
                <i class="fa-brands fa-airbnb"></i>
                <span>wanderlust</span>
            </a>
            <div class="nav-search">
                <form action="/listings" method="GET" class="search-form">
                    <input name="q" placeholder="Search destinations" class="search-input">
                    <button class="search-icon">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </form>
            </div>
            <div class="nav-menu">
                <a href="/listings/new" class="nav-link">Airbnb your home</a>
                <% if(!currUser) { %>
                    <a href="/signup" class="nav-link"><b>Sign up</b></a>
                    <a href="/login" class="nav-link">Log in</a>
                    <% } else { %>
                        <a href="/bookings" class="nav-link"><b>Trips</b></a>
                        <a href="/logout" class="nav-link">Log out</a>
                        <% } %>
                            <div class="nav-user">
                                <i class="fa-solid fa-bars"></i>
                                <% if(currUser) { %>
                                    <span class="nav-username">
                                        <b>
                                            <%= currUser.username %>
                                        </b>
                                    </span>
                                    <% } else { %>
                                        <i class="fa-solid fa-circle-user"></i>
                                        <% } %>
                            </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <% if(locals.success && locals.success.length) { %>
            <div class="alert alert-success" role="alert">
                <%= locals.success %>
            </div>
            <% } %>
                <% if(locals.error && locals.error.length) { %>
                    <div class="alert alert-danger" role="alert">
                        <%= locals.error %>
                    </div>
                    <% } %>
                        <%- body %>
    </div>


    <footer class="footer">
        <div class="footer-container">
            <div class="footer-info">
                <span>&copy; 2024 Wanderlust Private Limited</span>
                <span class="dot">.</span>
                <a href="#">Privacy</a>
                <span class="dot">.</span>
                <a href="#">Terms</a>
                <span class="dot">.</span>
                <a href="#">Sitemap</a>
                <span class="dot">.</span>
                <a href="#">Company details</a>
            </div>
            <div class="footer-social">
                <span><i class="fa-solid fa-globe"></i> English (IN)</span>
                <span>₹ INR</span>
                <div class="social-icons">
                    <i class="fa-brands fa-square-facebook"></i>
                    <i class="fa-brands fa-square-twitter"></i>
                    <i class="fa-brands fa-square-instagram"></i>
                </div>
            </div>
        </div>
    </footer>
    <script src="/js/script.js"></script>
</body>

</html>