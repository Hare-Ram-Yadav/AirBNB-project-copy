<% layout("/layouts/boilerplate") %>
    <div class="show-container">
        <div class="show-header">
            <h2>
                <%= listing.title %>
            </h2>
        </div>

        <div class="show-card">
            <% if (process.env.MAPBOX_TOKEN) { %>
                <div id="map" class="map-container"
                    data-geometry="<%= JSON.stringify(listing.geometry ? listing.geometry.coordinates : [77.2090, 28.6139]) %>"
                    data-title="<%= listing.title %>"></div>
                <% } %>

                    <div class="show-img-container mt-3">
                        <img src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTh8XHRyYXZlbHxlbnwwfHwwfHx8MA%3D%3D&auto=format&fit=crop&w=800&q=60' %>"
                            class="show-img" alt="listing_image">
                    </div>
                    <div class="show-details">
                        <p class="description">
                            <%= listing.description %>
                        </p>
                        <p class="price">&#8377; <%= listing.price.toLocaleString("en-IN") %> <span>/ night</span></p>

                        <div class="booking-section">
                            <form action="/listings/<%= listing._id %>/bookings" method="POST" class="booking-form">
                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="checkIn">Check-in</label>
                                        <input type="date" name="booking[checkIn]" id="checkIn" class="form-control"
                                            required>
                                    </div>
                                    <div class="form-group">
                                        <label for="checkOut">Check-out</label>
                                        <input type="date" name="booking[checkOut]" id="checkOut" class="form-control"
                                            required>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="guests">Guests</label>
                                    <select name="booking[guests]" id="guests" class="form-control">
                                        <option value="1">1 guest</option>
                                        <option value="2">2 guests</option>
                                        <option value="3">3 guests</option>
                                        <option value="4">4 guests</option>
                                    </select>
                                </div>
                                <button class="btn btn-primary btn-book">Reserve</button>
                                <p class="booking-hint">You won't be charged yet</p>
                            </form>
                        </div>
                        <p class="location"><i class="fa-solid fa-location-dot"></i>
                            <%= listing.location %>, <%= listing.country %>
                        </p>

                        <%- currUser && listing.owner && listing.owner._id && currUser._id &&
                            listing.owner._id.equals(currUser._id) ? ` <div class="show-btns">
                            <a href="/listings/${listing._id}/edit" class="btn btn-edit">Edit Listing</a>
                            <form method="POST" action="/listings/${listing._id}?_method=DELETE"
                                style="display:inline;">
                                <button class="btn btn-delete">Delete Listing</button>
                            </form>
                    </div>
                    ` : currUser && listing.owner && listing.owner.equals(currUser._id) ? `
                    <div class="show-btns">
                        <a href="/listings/${listing._id}/edit" class="btn btn-edit">Edit Listing</a>
                        <form method="POST" action="/listings/${listing._id}?_method=DELETE" style="display:inline;">
                            <button class="btn btn-delete">Delete Listing</button>
                        </form>
                    </div>
                    ` : '' %>
        </div>

        <hr>

        <div class="reviews-section">
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" class="mb-3 needs-validation" novalidate>
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <div class="star-rating">
                        <input type="hidden" name="review[rating]" id="rating" value="0">
                        <i class="fa-solid fa-star star" data-rating="1"></i>
                        <i class="fa-solid fa-star star" data-rating="2"></i>
                        <i class="fa-solid fa-star star" data-rating="3"></i>
                        <i class="fa-solid fa-star star" data-rating="4"></i>
                        <i class="fa-solid fa-star star" data-rating="5"></i>
                    </div>
                </div>
                <div class="mb-3 mt-3 form-group">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                        required></textarea>
                    <div class="invalid-feedback">Please submit some comments for review.</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
            </form>

            <hr>

            <p><b>All Reviews</b></p>
            <div class="row">
                <% for(review of (listing.reviews || [])) { %>
                    <div class="card col-5 ms-3 mb-3">
                        <div class="card-body">
                            <h5 class="card-title">@<%= review.author ? review.author.username : 'Anonymous' %>
                            </h5>
                            <p class="card-text">
                                <%= review.comment %>
                            </p>
                            <p class="card-text">
                                <%= review.rating %> stars
                            </p>
                            <form class="mb-3" method="POST"
                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-dark">Delete</button>
                            </form>
                        </div>
                    </div>
                    <% } %>
            </div>
        </div>
    </div>
    </div>

    <style>
        .show-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .show-header h2 {
            margin-bottom: 2rem;
            font-size: 1.65rem;
        }

        .show-img-container {
            width: 100%;
            height: 400px;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 2rem;
        }

        .show-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .show-details p {
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }

        .show-details .price {
            font-weight: 700;
            font-size: 1.25rem;
        }

        .show-details .location {
            color: var(--light-gray);
        }

        .show-btns {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            font-size: 1rem;
        }

        .btn-edit {
            background-color: var(--primary-color);
            color: white;
        }

        .btn-delete {
            background-color: #222;
            color: white;
        }

        .map-container {
            width: 100%;
            height: 300px;
            border-radius: 12px;
            margin-bottom: 2rem;
            margin-top: 1rem;
        }

        @media screen and (max-width: 768px) {
            .map-container {
                height: 250px;
            }
        }

        .star-rating {
            display: flex;
            gap: 5px;
        }

        .star {
            font-size: 1.5rem;
            color: #ddd;
            cursor: pointer;
            transition: color 0.2s;
        }

        .star:hover,
        .star.active {
            color: #ffc107;
        }
    </style>

    <% if (process.env.MAPBOX_TOKEN) { %>
        <script src='https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js'></script>
        <link href='https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css' rel='stylesheet' />
        <script>
            const mapToken = "<%- process.env.MAPBOX_TOKEN %>";
            mapboxgl.accessToken = mapToken;
            const mapEl = document.getElementById("map");
            if (mapEl) {
                const geometry = JSON.parse(mapEl.getAttribute("data-geometry"));
                const title = mapEl.getAttribute("data-title");

                const map = new mapboxgl.Map({
                    container: 'map', // container ID
                    // Choose from Mapbox's core styles, or make your own style with Mapbox Studio
                    style: 'mapbox://styles/mapbox/streets-v12', // style URL
                    center: geometry, // starting position [lng, lat]
                    zoom: 9 // starting zoom
                });

                // Create a default Marker and add it to the map.
                const marker1 = new mapboxgl.Marker({ color: 'red' })
                    .setLngLat(geometry)
                    .setPopup(new mapboxgl.Popup({ offset: 25 })
                        .setHTML(`<h4>${title}</h4><p>Exact location will be provided after booking</p>`))
                    .addTo(map);
            }
        </script>
        <% } %>

    <script>
        // Star rating functionality
        document.addEventListener('DOMContentLoaded', function() {
            const stars = document.querySelectorAll('.star');
            const ratingInput = document.getElementById('rating');

            stars.forEach(star => {
                star.addEventListener('click', function() {
                    const rating = this.getAttribute('data-rating');
                    ratingInput.value = rating;

                    // Remove active class from all stars
                    stars.forEach(s => s.classList.remove('active'));

                    // Add active class to clicked star and previous stars
                    for (let i = 0; i < rating; i++) {
                        stars[i].classList.add('active');
                    }
                });
            });
        });
    </script>